	segment2, segment3, sensor5, region3, sensor6, segment4, sensor7, sensor8,
	sensor9, sensor10, sensor11, segment5, segment6, segment7, sensor12,
	segment8, segment9, segment10, sensor13, segment11, sensor14, switch1,
	switch2, switch3, segment12, switch4, switch5.
