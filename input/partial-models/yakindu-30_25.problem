
abstract class CompositeElement {
    contains Region[] regions
}

class Region {
    contains Vertex[] vertices opposite region
}

abstract class Vertex {
    container Region region opposite vertices
    contains Transition[] outgoingTransition opposite source
    Transition[] incomingTransition opposite target
}

class Transition {
    container Vertex source opposite outgoingTransition
    Vertex[1] target opposite incomingTransition
}

abstract class Pseudostate extends Vertex.

abstract class RegularState extends Vertex.

class Entry extends Pseudostate.

class Exit extends Pseudostate.

class Choice extends Pseudostate.

class FinalState extends RegularState.

class State extends RegularState, CompositeElement.

class Statechart extends CompositeElement.



pred entryInRegion(r, Entry e) <->
    vertices(r, e).

error noEntryInRegion(Region r) <->
    !entryInRegion(r, _).

error multipleEntryInRegion(r) <->
    Entry(e1),
    Entry(e2),
    vertices(r, e1),
    vertices(r, e2),
    e1 != e2.

error incomingToEntry(t, Entry e) <->
    target(t, e).

error noOutgoingTransitionFromEntry(Entry e) <->
    !source(_, e).

error multipleTransitionFromEntry(Entry e, t1, t2) <->
    outgoingTransition(e, t1),
    outgoingTransition(e, t2),
    t1 != t2.


error outgoingFromExit(t, Exit e) <->
    source(t, e).


error outgoingFromFinal(t, FinalState e) <->
    source(t, e).


pred stateInRegion(r, State s) <->
    vertices(r, s).

error noStateInRegion(Region r) <->
    !stateInRegion(r, _).


error choiceHasNoOutgoing(Choice c) <->
    !source(_, c).

error choiceHasNoIncoming(Choice c) <->
    !target(_, c).

declare sct, transition1, region1, choice1, finalState1, finalState2, exit1,
	entry1, transition2, region2, finalState3, entry2, exit2, finalState4,
	transition3, finalState5, finalState6, finalState7, finalState8,
	finalState9, transition4, finalState10, state1, state2.
declare transition5, state3, region3, state4, entry3, exit3.
declare state5.
Statechart(sct).
Transition(transition1).
Region(region1).
Choice(choice1).
FinalState(finalState1).
FinalState(finalState2).
Entry(entry1).
Transition(transition2).
Region(region2).
State(finalState3).
Exit(exit2).
FinalState(finalState4).
Transition(transition3).
FinalState(finalState5).
node(finalState6).
!CompositeElement(finalState6).
!Region(finalState6).
!Vertex(finalState6).
!Transition(finalState6).
Exit(finalState7).
FinalState(finalState8).
FinalState(finalState9).
Transition(transition4).
FinalState(finalState10).
State(state1).
Choice(state2).
Transition(transition5).
State(state3).
Region(region3).
State(state4).
Entry(entry3).
Exit(exit3).
State(state5).
regions(sct, region1).
regions(state1, region3).
vertices(region1, choice1).
vertices(region1, finalState1).
vertices(region1, exit1).
vertices(region1, entry1).
vertices(region1, exit2).
vertices(region1, finalState5).
vertices(region1, finalState7).
vertices(region1, finalState10).
vertices(region1, state3).
vertices(region2, finalState3).
vertices(region2, entry2).
vertices(region2, finalState4).
vertices(region2, finalState8).
vertices(region2, state2).
vertices(region3, state4).
vertices(region3, entry3).
vertices(region3, exit3).
vertices(region3, state5).
outgoingTransition(choice1, transition2).
outgoingTransition(entry1, transition3).
outgoingTransition(state2, transition1).
outgoingTransition(entry3, transition5).
incomingTransition(choice1, transition1).
incomingTransition(exit1, transition2).
incomingTransition(state1, transition5).
incomingTransition(state2, transition4).
incomingTransition(exit3, transition3).
