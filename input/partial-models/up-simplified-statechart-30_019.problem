import builtin::view.


class State {
}
atom idle,seeding.

class Transition {
    Label[1] label 
    State[1] source
    State[1] target
}

enum Label {
    CANCEL, START, SHARE, RESTART, COMPLETED, PEERSDONE
}

@show
error pred HC1(t1, t2) <->
    label(t1,l),
    label(t2,l),
    t1 != t2,
    source(t1, s),
    source(t2, s).

@show
error pred HC2(s) <->
    State(s),
    !source(_, s).

pred hasTransition(s1, s2) <->
    source(t, s1),
    target(t, s2).
    
@show
error pred SC1(i, s) <->
    i == idle,
    s  == seeding,
    !hasTransition(i, s).

pred hasCancle(s) <->
    source(t, s),
    target(t, i),
    label(t,CANCEL),
    i == idle.    

@show
error pred SC2(s) <->
    State(s),
    !hasCancle(s).

declare transition1, transition2, transition3, transition4, transition5,
	transition6, transition7, transition8, transition9, transition10,
	transition11, transition12, transition13, transition14, transition15,
	transition16, state1, transition17, transition18, transition19, state2,
	transition20.
State(idle).
Transition(transition1).
Transition(transition2).
Transition(transition4).
Transition(transition5).
Transition(transition6).
Transition(transition7).
Transition(transition8).
Transition(transition9).
Transition(transition10).
Transition(transition11).
Transition(transition12).
Transition(transition13).
Transition(transition14).
Transition(transition15).
Transition(transition16).
State(state1).
Transition(transition17).
Transition(transition18).
Transition(transition19).
State(state2).
Transition(transition20).
label(transition1, PEERSDONE).
label(transition2, COMPLETED).
label(transition3, COMPLETED).
label(transition4, SHARE).
label(transition5, START).
label(transition6, CANCEL).
label(transition7, SHARE).
label(transition8, CANCEL).
label(transition9, RESTART).
label(transition10, RESTART).
label(transition11, PEERSDONE).
label(transition12, START).
label(transition13, PEERSDONE).
label(transition14, SHARE).
label(transition15, SHARE).
label(transition16, COMPLETED).
label(transition17, START).
label(transition18, CANCEL).
label(transition19, COMPLETED).
label(transition20, CANCEL).
source(transition2, seeding).
source(transition3, idle).
source(transition4, idle).
source(transition5, idle).
source(transition6, idle).
source(transition7, seeding).
source(transition8, seeding).
source(transition9, seeding).
source(transition10, idle).
source(transition11, idle).
